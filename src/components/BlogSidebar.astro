  LinkedIn:    `<path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"/>`,
  Reddit:      `<path d="M6.167 8a.831.831 0 0 0-.83.83c0 .459.372.84.83.831a.831.831 0 0 0 0-1.661m1.843 3.647c.315 0 1.403-.038 1.976-.611a.232.232 0 0 0 0-.306.213.213 0 0 0-.306 0c-.353.363-1.126.487-1.67.487-.545 0-1.308-.124-1.671-.487a.213.213 0 0 0-.306 0 .213.213 0 0 0 0 .306c.564.573 1.652.61 1.977.61zm.992-2.807c0 .458.373.83.831.83.458 0 .83-.381.83-.83a.831.831 0 0 0-1.66 0z"/><path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.828-1.165c-.315 0-.602.124-.812.325-.801-.573-1.9-.945-3.121-.993l.534-2.501 1.738.372a.83.83 0 1 0 .83-.869.83.83 0 0 0-.744.468l-1.938-.41a.203.203 0 0 0-.153.028.186.186 0 0 0-.086.134l-.592 2.788c-1.24.038-2.358.41-3.17.992-.21-.2-.496-.324-.81-.324a1.163 1.163 0 0 0-.478 2.224c-.02.115-.029.23-.029.344 0 1.795 2.091 3.256 4.669 3.256 2.577 0 4.668-1.451 4.668-3.256 0-.114-.01-.238-.029-.344.528-.105.926-.601.926-1.108a1.163 1.163 0 0 0-1.165-1.116z"/>`,
  'crates.io': `<path d="M239.66 10.56a32 32 0 0 1 32.69 0l208 124.37A32 32 0 0 1 496 162.48v187.05a32 32 0 0 1-15.65 27.55l-208 124.37a32 32 0 0 1-32.69 0l-208-124.37A32 32 0 0 1 16 349.53V162.48a32 32 0 0 1 15.65-27.55zM256 64L80 166.4 256 268.8l176-102.4zm-176 224v102.4L256 492.8V390.4zm208 128.8 144-86.4V228.8l-144 86.4z"/>`,
  npm:         `<path d="M0 0v16h16V0zm13.5 13.5h-3v-9h-3v9h-4.5v-12h10.5z"/>`,
};

const SOCIAL_VIEWBOXES: Record<string, string> = {
  'crates.io': '0 0 512 512',
};

const FILTERS = [
  { type: 'project',   label: 'Projects' },
  { type: 'article',   label: 'Articles' },
  { type: 'reference', label: 'References' },
] as const;
---

<nav class="pf-sidebar" aria-label="Site navigation">
  <div class="pf-sidebar__logo-wrap">
    <a href="/" class="pf-sidebar__logo">{SITE_HANDLE}</a>
    <p class="pf-sidebar__tagline">{AUTHOR_TAGLINE}</p>
  </div>

  <div class="pf-search-bar">
    <svg class="pf-search-bar__icon" width="14" height="14" viewBox="0 0 15 15" fill="none" aria-hidden="true">
      <circle cx="6.5" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.5"/>
      <line x1="10" y1="10" x2="14" y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
    <input
      type="search"
      class="pf-search-bar__input"
      placeholder="title, description, tags…"
      disabled
      aria-label="Search content (not available on article pages)"
    />
  </div>

  <div>
    <p class="pf-sidebar__section-label">Browse</p>
    <div class="pf-sidebar__filters">
      {FILTERS.map(({ type, label }) => (
        <a
          href={`/?f=${type}`}
          class={`pf-filter-btn pf-filter-btn--${type}`}
          data-filter-type={type}
        >
          <span class="pf-filter-btn__dot" aria-hidden="true"></span>
          <span class="pf-filter-btn__label">{label}</span>
        </a>
      ))}
    </div>
  </div>

  <div class="pf-sidebar__nav">
    <a href="/about" class="pf-nav-link">About</a>
  </div>

  <div class="pf-sidebar__support">
    <a
      href="https://www.buymeacoffee.com/dominikj111"
      class="pf-support-btn pf-support-btn--coffee pf-support-btn--cookie"
      target="_blank"
      rel="noopener noreferrer"
    >
      ☕ Buy me a coffee
    </a>
  </div>

  <div class="pf-sidebar__socials">
    {SOCIALS.map(({ href, label }) => {
      const paths = SOCIAL_ICONS[label];
      if (!paths) return null;
      const viewBox = SOCIAL_VIEWBOXES[label] ?? '0 0 16 16';
      return (
        <a href={href} class="pf-social-link" target="_blank" rel="noopener noreferrer me" aria-label={label} title={label}>
          <svg viewBox={viewBox} width="17" height="17" fill="currentColor" aria-hidden="true" set:html={paths} />
        </a>
      );
    })}
  </div>
</nav>
