---
// Persistent navigation sidebar for blog/article pages.
import { SITE_HANDLE, AUTHOR_TAGLINE, SOCIALS } from '../config';

// Icons keyed by label — must match labels defined in config.ts SOCIALS.
const SOCIAL_ICONS: Record<string, string> = {
