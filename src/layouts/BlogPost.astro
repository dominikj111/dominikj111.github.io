---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import BlogSidebar from '../components/BlogSidebar.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { AUTHOR_NAME } from '../config';

type Props = CollectionEntry<'blog'>['data'] & {
  /** When true the article body stretches to the full content area width */
  wide?: boolean;
};

const { title, description, pubDate, updatedDate, heroImage, tags, wide = false } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead
      title={`${title} — dominikj111`}
      description={description}
      isArticle={true}
      pubDate={pubDate}
    />
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      "headline": title,
      "description": description,
      "datePublished": pubDate.toISOString(),
      ...(updatedDate ? { "dateModified": updatedDate.toISOString() } : {}),
      "author": {
        "@type": "Person",
        "name": AUTHOR_NAME,
        "url": Astro.site?.toString()
      },
      "publisher": {
        "@type": "Person",
        "name": AUTHOR_NAME,
        "url": Astro.site?.toString()
      },
      "url": Astro.url.toString()
    })} />
  </head>

  <body class="pf-blog-body">
    <div class="pf-blog-layout">
      <BlogSidebar />

      <main class="pf-blog-main">
        <a href="/" class="pf-blog-back">← Back</a>

        <article class:list={['pf-blog-article', wide && 'pf-blog-article--wide']}>
          <header class="pf-blog-article__header">
            <div class="pf-blog-article__type-row">
              <span class="pf-type-dot pf-type-dot--article" aria-hidden="true"></span>
              <span class="pf-type-label">Article</span>
            </div>
            <h1 class="pf-blog-article__title">{title}</h1>
            <div class="pf-blog-article__meta">
              <time datetime={pubDate.toISOString()}>
                <FormattedDate date={pubDate} />
              </time>
              {updatedDate && (
                <span class="pf-blog-article__updated">
                  Updated <FormattedDate date={updatedDate} />
                </span>
              )}
            </div>
            {tags && tags.length > 0 && (
              <div class="pf-card__tags pf-blog-article__tags">
                {tags.map((tag: string) => (
                  <span class={`pf-tag${tag === 'draft' ? ' pf-tag--draft' : ''}`}>{tag}</span>
                ))}
              </div>
            )}
          </header>


          <div class="pf-prose">
            <slot />
          </div>
        </article>
      </main>
    </div>
  </body>
</html>
